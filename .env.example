# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── STRIPE ────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Connect → Settings → Client ID
STRIPE_CLIENT_ID=ca_...

# Stripe Price IDs — create them in Dashboard → Products
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_...

# Stripe Issuing (HERMÈS CIBLE 3) — mettre 'true' UNIQUEMENT après approbation
# du card program par Stripe Sales (KYB 2026). Tant que 'false' (ou absent),
# les commandes de cartes sont persistées en statut 'queued' sans débit.
STRIPE_ISSUING_ENABLED=false

# ─── GROQ (Transcription vocale Whisper) ───────────────────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ─── OPENROUTER (IA parsing — modèles gratuits disponibles) ────────────────────
# openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ─── MISTRAL (OCR factures/reçus — pipeline Dext-like, stage 1) ────────────────
# mistral.ai → La Plateforme → API Keys. Moteur OCR doc le moins cher du marché
# (~$1 / 1000 pages), natif PDF multi-pages, excellent en français. Utilisé en
# stage 1 du pipeline /api/ai/ocr-mistral (mistral-ocr-latest → Gemini Flash).
# Sans cette clé, le scan OCR repli automatiquement sur Gemini (ocr-receipt).
MISTRAL_API_KEY=

# ─── RESEND (Envoi d'emails) ────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contact@factu.me
RESEND_FROM_NAME=Factu.me

# ─── UPSTASH REDIS (Rate limiting distribué) ───────────────────────────────────────
# upstash.com → Console → Create Redis Database → REST API
# Requis pour le rate limiting distribué en production
# Facultatif en dev (fallback sur rate limiting in-memory)
UPSTASH_REDIS_REST_URL=https://xxx-xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXUxxx...

# ─── SENTRY (Monitoring et tracking d'erreurs) ───────────────────────────────────
# sentry.io → Settings → Projects → Create Project → Next.js
# Facultatif mais recommandé pour le monitoring en production
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ─── GOOGLE ANALYTICS (Analytics) ──────────────────────────────────────────────────
# analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://factu.me

# ─── WEB PUSH NOTIFICATIONS (PWA) ──────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNxxx...
VAPID_PRIVATE_KEY=xxx...
VAPID_SUBJECT=mailto:contact@factu.me

# ─── CHORUS PRO (optionnel — facturation secteur public) ───────────────────────
# CHORUS_PRO_CLIENT_ID=
# CHORUS_PRO_CLIENT_SECRET=
# CHORUS_PRO_LOGIN=
# CHORUS_PRO_PASSWORD=

# ─── GOOGLE CALENDAR (optionnel — synchronisation agenda) ──────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# 1. Créer un projet OAuth 2.0
# 2. Activer "Google Calendar API"
# 3. Créer un ID client OAuth avec URI de redirection autorisée
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI de redirection (remplacer avec votre domaine en production)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ─── SIGNATURE ÉLECTRONIQUE CONFORME eIDAS (optionnel — niveau Qualifié QES) ─────
# Tiers de Confiance Qualifié (TQT) pour signatures certifiées eIDAS
# Fournisseurs certifiés : ANSSI, DigiCert, GlobalSign, DocuSign Europe
# Règlement (UE) N° 910/2014 - http://data.europa.eu/eli/reg/2014/910/oj

# ─── SIGNATURE ÉLECTRONIQUE CONFORME eIDAS (AdES - GRATUIT)
# Factu.me utilise le niveau Avancé (AdES) du règlement eIDAS
# Horodatage certifié via freeTSA.org (service gratuit)
# Aucune configuration requise - tout est inclus !
# Plus d'infos : https://freetsa.org/

# ─── SUPER PDP — Facturation électronique (réforme 2026) ────────────────────────
# Plateforme Agréée (PA/PDP) pour la transmission légale des factures
# Inscription : https://www.superpdp.tech → Créer un compte → API
# Documentation : https://www.superpdp.tech/documentation/ (pages 2-11) + openapi/
#
# Modèle "marque grise" : factu.me est le seul client officiel SuperPDP. Chaque
# utilisateur connecte SON propre compte SuperPDP via OAuth (Authorization Code),
# de sorte que le token porte SON SIREN (émetteur légal), pas celui de factu.me.
#
# 1. Créer un compte Super PDP (un seul pour factu.me = Abonnement Direct)
# 2. Applications → Créer une application OAuth2 → récupérer client_id / client_secret
# 3. Dans cette application, enregistrer la Redirect URI (SUPER_PDP_REDIRECT_URI)
# 4. Copier client_id / client_secret ci-dessous (jamais en clair dans le repo)
SUPER_PDP_CLIENT_ID=019xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPER_PDP_CLIENT_SECRET=sp_secret_xxxxxxxx
# URI de redirection OAuth (doit être enregistrée côté SuperPDP)
SUPER_PDP_REDIRECT_URI=https://factu.me/api/superpdp/callback
# Mode sandbox (true en dev, false en production). Détermine le scheme du tunnel OAuth.
SUPER_PDP_SANDBOX=true

# ─── CHIFFREMENT DES TOKENS OAuth (AES-256-GCM) ───────────────────────────────
# Clé utilisée par encryptToken()/decryptToken() (lib/utils) pour chiffrer les
# tokens SuperPDP, Stripe Connect, etc. en base. 32 octets encodés en base64.
# Générer avec : openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=base64_32_bytes_key_here

# ─── CRON SECRET (sécurité des cron jobs Vercel) ────────────────────────────────
# Un secret aléatoire pour protéger les endpoints cron
# Générer avec : openssl rand -hex 32
CRON_SECRET=votre_secret_aleatoire_ici